{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: docker compose then Remote Attach orders",
            "type": "debugpy",
            "request": "attach",
            "preLaunchTask": "wait-for-debugpy",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/services/orders",
                    "remoteRoot": "/app"
                }
            ],
            "django": true,
            "justMyCode": true
        },
                {
            "name": "Python: Remote Attach orders",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/services/orders",
                    "remoteRoot": "/app"
                }
            ],
            "django": true,
            "justMyCode": true
        },
        {   
            "name": "Launch Chrome against localhost",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "/app/src/*": "${workspaceFolder}/frontend/src/*"
  }
        }
    ]
}